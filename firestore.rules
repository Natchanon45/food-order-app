rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasRole(roles) { return signedIn() && profile().active == true && profile().role in roles; }
    function adminRole() { return hasRole(['owner', 'admin', 'super_admin']); }
    function cashierRole() { return hasRole(['owner', 'cashier', 'super_admin']); }
    function kitchenRole() { return hasRole(['owner', 'kitchen', 'super_admin']); }
    function staffRole() { return hasRole(['owner', 'admin', 'super_admin', 'cashier', 'kitchen']); }
    function superAdminRole() { return hasRole(['super_admin']); }
    function tenantMembershipPath(tenantId) { return /databases/$(database)/documents/tenants/$(tenantId)/memberships/$(request.auth.uid); }
    function tenantOwner(tenantId) { return signedIn() && (get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUid == request.auth.uid || get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerEmail == request.auth.token.email); }
    function profileTenantMember(tenantId) { return signedIn() && profile().active == true && profile().tenantId == tenantId; }
    function tenantMember(tenantId) { return signedIn() && (tenantOwner(tenantId) || (exists(tenantMembershipPath(tenantId)) && get(tenantMembershipPath(tenantId)).data.active == true) || profileTenantMember(tenantId)); }
    function tenantHasRole(tenantId, roles) { return signedIn() && (tenantOwner(tenantId) || (exists(tenantMembershipPath(tenantId)) && get(tenantMembershipPath(tenantId)).data.active == true && get(tenantMembershipPath(tenantId)).data.role in roles) || (profileTenantMember(tenantId) && profile().role in roles)); }
    function tenantAdminRole(tenantId) { return superAdminRole() || tenantHasRole(tenantId, ['owner', 'admin', 'super_admin']); }
    function tenantCashierRole(tenantId) { return superAdminRole() || tenantHasRole(tenantId, ['owner', 'cashier', 'super_admin']); }
    function tenantKitchenRole(tenantId) { return superAdminRole() || tenantHasRole(tenantId, ['owner', 'kitchen', 'super_admin']); }
    function tenantStaffRole(tenantId) { return superAdminRole() || tenantHasRole(tenantId, ['owner', 'admin', 'super_admin', 'cashier', 'kitchen']); }
    function validOrderBase() { return request.resource.data.status == 'pending' && request.resource.data.items is list && request.resource.data.items.size() > 0 && request.resource.data.items.size() <= 100 && request.resource.data.totalAmount is number && request.resource.data.totalAmount >= 0; }
    function validDeliveryOrder() { return validOrderBase() && request.resource.data.orderType == 'delivery' && request.resource.data.paymentStatus in ['unpaid', 'pending_verification']; }
    function validTakeawayOrder() { return validOrderBase() && request.resource.data.orderType == 'takeaway' && request.resource.data.queueNo is string && request.resource.data.pickupStatus == 'waiting' && request.resource.data.paymentStatus in ['unpaid', 'pending_verification'] && ((request.resource.data.customerName is string && request.resource.data.customerName.size() > 0) || (request.resource.data.customerPhone is string && request.resource.data.customerPhone.size() > 0)); }
    function validTableOrder() { return validOrderBase() && request.resource.data.tableCode is string && request.resource.data.tableToken is string && get(/databases/$(database)/documents/tables/$(request.resource.data.tableCode)).data.status == 'occupied' && get(/databases/$(database)/documents/tables/$(request.resource.data.tableCode)).data.orderToken == request.resource.data.tableToken; }
    function activeTableOrder() { return resource.data.tableCode is string && resource.data.tableToken is string && get(/databases/$(database)/documents/tables/$(resource.data.tableCode)).data.status == 'occupied' && get(/databases/$(database)/documents/tables/$(resource.data.tableCode)).data.orderToken == resource.data.tableToken; }
    function tenantPayloadMatches(tenantId) { return request.resource.data.tenantId == tenantId || request.resource.data.shopId == tenantId; }
    function tenantResourceMatches(tenantId) { return resource.data.tenantId == tenantId || resource.data.shopId == tenantId; }
    function retailTenantWrite(tenantId) { return signedIn() && tenantHasRole(tenantId, ['owner', 'admin', 'manager', 'cashier', 'super_admin']) && tenantPayloadMatches(tenantId); }
    function retailStockUpdate(tenantId) { return retailTenantWrite(tenantId) && tenantResourceMatches(tenantId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'tenantId', 'updatedAt', 'updatedAtServer']); }
    function validPosStockUpdate(tenantId) { return signedIn() && tenantPayloadMatches(tenantId) && tenantResourceMatches(tenantId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'tenantId', 'updatedAt', 'updatedAtServer']); }
    function validTenantTableOrder(tenantId) { return validOrderBase() && tenantPayloadMatches(tenantId) && request.resource.data.tableCode is string && request.resource.data.tableToken is string && get(/databases/$(database)/documents/tenants/$(tenantId)/tables/$(request.resource.data.tableCode)).data.status == 'occupied' && get(/databases/$(database)/documents/tenants/$(tenantId)/tables/$(request.resource.data.tableCode)).data.orderToken == request.resource.data.tableToken; }
    function activeTenantTableOrder(tenantId) { return resource.data.tableCode is string && resource.data.tableToken is string && get(/databases/$(database)/documents/tenants/$(tenantId)/tables/$(resource.data.tableCode)).data.status == 'occupied' && get(/databases/$(database)/documents/tenants/$(tenantId)/tables/$(resource.data.tableCode)).data.orderToken == resource.data.tableToken; }
    function validPublicTenantTakeaway(tenantId) { return tenantPayloadMatches(tenantId) && validTakeawayOrder(); }
    function validPublicTenantDelivery(tenantId) { return tenantPayloadMatches(tenantId) && validDeliveryOrder(); }
    function validRetailSale(tenantId) { return tenantPayloadMatches(tenantId) && request.resource.data.status == 'completed' && request.resource.data.channel == 'retail-pos' && request.resource.data.items is list && request.resource.data.items.size() > 0 && request.resource.data.items.size() <= 100 && request.resource.data.totalQty is number && request.resource.data.totalQty > 0 && request.resource.data.totalAmount is number && request.resource.data.totalAmount >= 0 && request.resource.data.cashierId == request.auth.uid; }
    function validPosSale(tenantId) { return signedIn() && validRetailSale(tenantId); }
    function validStockMovement(tenantId) { return tenantPayloadMatches(tenantId) && request.resource.data.productId is string && request.resource.data.type in ['sale', 'purchase', 'adjustment', 'return'] && request.resource.data.direction in ['in', 'out'] && request.resource.data.qty is number && request.resource.data.qty > 0 && request.resource.data.createdBy == request.auth.uid; }
    function validPosSaleMovement(tenantId) { return signedIn() && validStockMovement(tenantId) && request.resource.data.type == 'sale' && request.resource.data.direction == 'out'; }
    function validPosSaleItem(tenantId) { return signedIn() && tenantPayloadMatches(tenantId) && request.resource.data.saleId is string && request.resource.data.productId is string && request.resource.data.channel == 'retail-pos' && request.resource.data.orderType == 'pos' && request.resource.data.qty is number && request.resource.data.qty > 0; }
    function validPosCounter(tenantId) { return signedIn() && tenantPayloadMatches(tenantId) && request.resource.data.prefix == 'POS' && request.resource.data.dateKey is string && request.resource.data.current is number && request.resource.data.current >= 0; }
    function validTakeawayCounter(tenantId) { return tenantPayloadMatches(tenantId) && request.resource.data.counterType == 'takeaway' && request.resource.data.dateKey is string && request.resource.data.current is number && request.resource.data.current >= 0 && request.resource.data.lastQueueNo is string; }
    function validPosDailySummary(tenantId) { return signedIn() && tenantPayloadMatches(tenantId) && request.resource.data.dateKey is string && request.resource.data.channel == 'retail-pos' && request.resource.data.totalAmount is number && request.resource.data.billCount is number; }
    function validPosSyncQueue(tenantId) { return signedIn() && tenantPayloadMatches(tenantId) && request.resource.data.saleId is string && request.resource.data.channel == 'retail-pos' && request.resource.data.orderType == 'pos' && request.resource.data.syncStatus in ['pending', 'syncing', 'synced', 'failed', 'conflict']; }
    function validPosAuditLog(tenantId) { return signedIn() && tenantPayloadMatches(tenantId) && request.resource.data.action is string && request.resource.data.createdBy == request.auth.uid; }
    function validRetailCustomer(tenantId) { return tenantPayloadMatches(tenantId) && request.resource.data.id is string && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 120 && (!('points' in request.resource.data) || (request.resource.data.points is number && request.resource.data.points >= 0)); }
    function validRetailSaleEnrichment(tenantId) { return tenantPayloadMatches(tenantId) && tenantResourceMatches(tenantId) && resource.data.channel == 'retail-pos' && resource.data.status == 'completed' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['customerId','customerCode','customerName','customerPhone','loyalty','shopId','tenantId','updatedAt','updatedAtServer']); }
    function validLoyaltyLedgerEntry(tenantId) { return tenantPayloadMatches(tenantId) && request.resource.data.id is string && request.resource.data.customerId is string && request.resource.data.saleId is string && request.resource.data.pointsUsed is number && request.resource.data.pointsUsed >= 0 && request.resource.data.pointsEarned is number && request.resource.data.pointsEarned >= 0 && request.resource.data.balanceBefore is number && request.resource.data.balanceBefore >= 0 && request.resource.data.balanceAfter is number && request.resource.data.balanceAfter >= 0 && request.resource.data.createdBy == request.auth.uid; }
    function validHeldBill(tenantId) { return tenantPayloadMatches(tenantId) && request.resource.data.id is string && request.resource.data.status == 'held' && request.resource.data.items is list && request.resource.data.items.size() > 0 && request.resource.data.items.size() <= 100 && request.resource.data.total is number && request.resource.data.total >= 0 && request.resource.data.createdBy == request.auth.uid; }
    function validRetailShift(tenantId) { return tenantPayloadMatches(tenantId) && request.resource.data.id is string && request.resource.data.cashierName is string && request.resource.data.terminalCode is string && request.resource.data.openingCash is number && request.resource.data.openingCash >= 0 && request.resource.data.status in ['open', 'closed'] && request.resource.data.createdBy == request.auth.uid && (request.resource.data.status == 'open' || request.resource.data.closedBy == request.auth.uid); }
    function validRetailReturn(tenantId) { return tenantPayloadMatches(tenantId) && request.resource.data.id is string && request.resource.data.saleId is string && request.resource.data.items is list && request.resource.data.items.size() > 0 && request.resource.data.items.size() <= 100 && request.resource.data.refundTotal is number && request.resource.data.refundTotal >= 0 && request.resource.data.createdBy == request.auth.uid; }
    function validRetailReturnSaleUpdate(tenantId) { return tenantPayloadMatches(tenantId) && tenantResourceMatches(tenantId) && resource.data.channel == 'retail-pos' && resource.data.status == 'completed' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['returns','refundTotal','loyalty','updatedAt','updatedAtServer']); }

    match /menus/{menuId} { allow read: if true; allow create, update, delete: if adminRole(); }
    match /settings/{settingId} { allow read: if true; allow create, update, delete: if adminRole(); }
    match /tables/{tableId} { allow read: if true; allow create, delete: if adminRole(); allow update: if adminRole() || cashierRole() || (kitchenRole() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'orderToken', 'sessionStartedAt', 'currentRound', 'updatedAt', 'tenantId', 'shopId']) && resource.data.status == 'occupied' && request.resource.data.status == 'available' && request.resource.data.orderToken == '') || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentRound', 'updatedAt']) && resource.data.status == 'occupied' && request.resource.data.orderToken == resource.data.orderToken); }
    match /orders/{orderId} { allow get: if true; allow list: if staffRole() || activeTableOrder(); allow create: if validDeliveryOrder() || validTableOrder() || validTakeawayOrder(); allow update: if cashierRole() || kitchenRole() || adminRole(); allow delete: if superAdminRole(); }
    match /customerProfiles/{userId} { allow read, create, update, delete: if signedIn() && request.auth.uid == userId && (request.method == 'delete' || (request.resource.data.addresses is list && request.resource.data.addresses.size() <= 5)); }
    match /deliveryCustomers/{customerId} { allow read, write: if adminRole(); }
    match /users/{userId} { allow read: if signedIn() && (request.auth.uid == userId || superAdminRole()); allow create, update, delete: if superAdminRole(); }
    match /tenantSlugs/{slug} { allow read: if true; allow write: if superAdminRole(); }

    match /tenants/{tenantId} {
      allow read: if true; allow create, update, delete: if superAdminRole();
      match /menus/{menuId} { allow read: if true; allow create, update, delete: if tenantAdminRole(tenantId); }
      match /settings/{settingId} { allow read: if true; allow create, update, delete: if tenantAdminRole(tenantId); }
      match /products/{productId} { allow read: if true; allow create: if tenantAdminRole(tenantId) && tenantPayloadMatches(tenantId); allow update: if (tenantAdminRole(tenantId) && tenantPayloadMatches(tenantId) && tenantResourceMatches(tenantId)) || retailStockUpdate(tenantId) || validPosStockUpdate(tenantId); allow delete: if tenantAdminRole(tenantId) && tenantResourceMatches(tenantId); }
      match /sales/{saleId} { allow read: if tenantMember(tenantId); allow create: if (retailTenantWrite(tenantId) && validRetailSale(tenantId)) || validPosSale(tenantId); allow update: if (tenantAdminRole(tenantId) && tenantResourceMatches(tenantId)) || (retailTenantWrite(tenantId) && validRetailSaleEnrichment(tenantId)) || (retailTenantWrite(tenantId) && validRetailReturnSaleUpdate(tenantId)); allow delete: if tenantAdminRole(tenantId) && tenantResourceMatches(tenantId); }
      match /saleItems/{itemId} { allow read: if tenantMember(tenantId); allow create: if validPosSaleItem(tenantId); allow update, delete: if false; }
      match /stockMovements/{movementId} { allow read: if tenantMember(tenantId); allow create: if (retailTenantWrite(tenantId) && validStockMovement(tenantId)) || validPosSaleMovement(tenantId); allow update, delete: if false; }
      match /counters/{counterId} { allow read: if signedIn() || counterId.matches('takeaway_.*'); allow create, update: if validPosCounter(tenantId) || validTakeawayCounter(tenantId); allow delete: if false; }
      match /dailySummary/{summaryId} { allow read: if tenantMember(tenantId); allow create, update: if validPosDailySummary(tenantId); allow delete: if false; }
      match /syncQueue/{queueId} { allow read: if signedIn(); allow create, update: if validPosSyncQueue(tenantId); allow delete: if false; }
      match /auditLogs/{auditId} { allow read: if tenantAdminRole(tenantId); allow create: if validPosAuditLog(tenantId); allow update, delete: if false; }
      match /customers/{customerId} { allow read: if tenantMember(tenantId); allow create: if retailTenantWrite(tenantId) && validRetailCustomer(tenantId); allow update: if retailTenantWrite(tenantId) && tenantResourceMatches(tenantId) && request.resource.data.id == resource.data.id && validRetailCustomer(tenantId); allow delete: if tenantHasRole(tenantId, ['owner', 'admin', 'manager', 'super_admin']) && tenantResourceMatches(tenantId); }
      match /loyaltyLedger/{entryId} { allow read: if tenantMember(tenantId); allow create: if retailTenantWrite(tenantId) && validLoyaltyLedgerEntry(tenantId); allow update, delete: if false; }
      match /heldBills/{heldBillId} { allow read: if tenantMember(tenantId); allow create, update: if retailTenantWrite(tenantId) && validHeldBill(tenantId); allow delete: if tenantHasRole(tenantId, ['owner', 'admin', 'manager', 'cashier', 'super_admin']) && tenantResourceMatches(tenantId); }
      match /shifts/{shiftId} { allow read: if tenantMember(tenantId); allow create: if retailTenantWrite(tenantId) && validRetailShift(tenantId); allow update: if retailTenantWrite(tenantId) && tenantResourceMatches(tenantId) && request.resource.data.id == resource.data.id && validRetailShift(tenantId); allow delete: if false; }
      match /returns/{returnId} { allow read: if tenantMember(tenantId); allow create: if retailTenantWrite(tenantId) && validRetailReturn(tenantId); allow update, delete: if false; }
      match /tables/{tableId} { allow read: if true; allow create, delete: if tenantAdminRole(tenantId); allow update: if tenantAdminRole(tenantId) || tenantCashierRole(tenantId) || (tenantKitchenRole(tenantId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'orderToken', 'sessionStartedAt', 'currentRound', 'updatedAt', 'tenantId', 'shopId']) && resource.data.status == 'occupied' && request.resource.data.status == 'available' && request.resource.data.orderToken == '') || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentRound', 'updatedAt', 'tenantId', 'shopId']) && resource.data.status == 'occupied' && request.resource.data.orderToken == resource.data.orderToken); }
      match /orders/{orderId} { allow get: if true; allow list: if tenantStaffRole(tenantId) || activeTenantTableOrder(tenantId); allow create: if superAdminRole() || validPublicTenantDelivery(tenantId) || validPublicTenantTakeaway(tenantId) || validTenantTableOrder(tenantId); allow update: if tenantCashierRole(tenantId) || tenantKitchenRole(tenantId) || tenantAdminRole(tenantId); allow delete: if superAdminRole() || tenantHasRole(tenantId, ['owner', 'super_admin']); }
      match /deliveryCustomers/{customerId} { allow read, write: if tenantAdminRole(tenantId); }
      match /memberships/{userId} { allow read: if signedIn() && (request.auth.uid == userId || superAdminRole() || tenantAdminRole(tenantId)); allow create, update, delete: if superAdminRole(); }
      match /notificationTokens/{tokenId} { allow read: if superAdminRole() || (signedIn() && resource.data.uid == request.auth.uid); allow create: if tenantMember(tenantId) && request.resource.data.uid == request.auth.uid && request.resource.data.tenantId == tenantId && request.resource.data.token is string && request.resource.data.active == true; allow update: if tenantMember(tenantId) && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid && request.resource.data.tenantId == tenantId; allow delete: if signedIn() && (resource.data.uid == request.auth.uid || superAdminRole()); }
    }

    match /shops/{shopId}/{document=**} { allow read: if superAdminRole(); allow write: if false; }
  }
}
