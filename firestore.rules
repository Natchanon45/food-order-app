rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userActive() {
      return signedIn() && profile().active == true;
    }

    function hasRole(roles) {
      return userActive() && profile().role in roles;
    }

    function superAdminRole() {
      return hasRole(['super_admin']);
    }

    function tenantDoc(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)).data;
    }

    function memberPath(tenantId) {
      return /databases/$(database)/documents/tenants/$(tenantId)/memberships/$(request.auth.uid);
    }

    function memberData(tenantId) {
      return get(memberPath(tenantId)).data;
    }

    function tenantOwner(tenantId) {
      return signedIn() && (
        tenantDoc(tenantId).ownerUid == request.auth.uid ||
        tenantDoc(tenantId).ownerEmail == request.auth.token.email
      );
    }

    function tenantMember(tenantId) {
      return signedIn() && (
        tenantOwner(tenantId) ||
        superAdminRole() ||
        (exists(memberPath(tenantId)) && memberData(tenantId).active == true) ||
        (userActive() && profile().tenantId == tenantId)
      );
    }

    function tenantRole(tenantId) {
      return tenantOwner(tenantId) ? 'owner' :
        (exists(memberPath(tenantId)) && memberData(tenantId).active == true ? memberData(tenantId).role : profile().role);
    }

    function tenantHasRole(tenantId, roles) {
      return tenantMember(tenantId) && (superAdminRole() || tenantRole(tenantId) in roles);
    }

    function canManageEverything(tenantId) {
      return tenantHasRole(tenantId, ['owner']);
    }

    function canManageStore(tenantId) {
      return tenantHasRole(tenantId, ['owner', 'manager', 'admin']);
    }

    function canSell(tenantId) {
      return tenantHasRole(tenantId, ['owner', 'manager', 'admin', 'cashier']);
    }

    function canManageStock(tenantId) {
      return tenantHasRole(tenantId, ['owner', 'manager', 'admin', 'stock']);
    }

    function canManageMembers(tenantId) {
      return tenantHasRole(tenantId, ['owner', 'cashier']);
    }

    function payloadTenantMatches(tenantId) {
      return request.resource.data.tenantId == tenantId || request.resource.data.shopId == tenantId;
    }

    function resourceTenantMatches(tenantId) {
      return resource.data.tenantId == tenantId || resource.data.shopId == tenantId;
    }

    function validSale(tenantId) {
      return payloadTenantMatches(tenantId)
        && request.resource.data.status == 'completed'
        && request.resource.data.channel == 'retail-pos'
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 100
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount >= 0;
    }

    function validMovement(tenantId) {
      return payloadTenantMatches(tenantId)
        && request.resource.data.productId is string
        && request.resource.data.type in ['sale', 'purchase', 'adjustment', 'return', 'import']
        && request.resource.data.direction in ['in', 'out']
        && request.resource.data.qty is number
        && request.resource.data.qty > 0;
    }

    function validReturn(tenantId) {
      return payloadTenantMatches(tenantId)
        && request.resource.data.saleId is string
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.refundTotal is number
        && request.resource.data.refundTotal > 0;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || superAdminRole());
      allow create, update, delete: if superAdminRole();
    }

    match /tenantSlugs/{slug} {
      allow read: if true;
      allow write: if superAdminRole();
    }

    match /menus/{menuId} {
      allow read: if true;
      allow write: if hasRole(['owner', 'admin', 'manager', 'super_admin']);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if hasRole(['owner', 'admin', 'manager', 'super_admin']);
    }

    match /tables/{tableId} {
      allow read: if true;
      allow write: if hasRole(['owner', 'admin', 'manager', 'cashier', 'super_admin']);
    }

    match /orders/{orderId} {
      allow get: if true;
      allow list, create, update: if hasRole(['owner', 'admin', 'manager', 'cashier', 'kitchen', 'super_admin']);
      allow delete: if hasRole(['owner', 'super_admin']);
    }

    match /customerProfiles/{userId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /deliveryCustomers/{customerId} {
      allow read, write: if hasRole(['owner', 'admin', 'manager', 'super_admin']);
    }

    match /tenants/{tenantId} {
      allow read: if true;
      allow create, update, delete: if superAdminRole();

      match /menus/{menuId} {
        allow read: if true;
        allow write: if canManageStore(tenantId);
      }

      match /settings/{settingId} {
        allow read: if true;
        allow write: if canManageStore(tenantId);
      }

      match /products/{productId} {
        allow read: if true;
        allow create: if (canManageStock(tenantId) || canSell(tenantId)) && payloadTenantMatches(tenantId);
        allow update: if ((canManageStock(tenantId) || canSell(tenantId)) && payloadTenantMatches(tenantId)) ||
          ((canManageStock(tenantId) || canSell(tenantId)) && resourceTenantMatches(tenantId));
        allow delete: if canManageStock(tenantId) && resourceTenantMatches(tenantId);
      }

      match /sales/{saleId} {
        allow read: if tenantMember(tenantId);
        allow create: if canSell(tenantId) && validSale(tenantId);
        allow update: if (canManageStore(tenantId) && resourceTenantMatches(tenantId)) ||
          (canSell(tenantId) && payloadTenantMatches(tenantId));
        allow delete: if canManageEverything(tenantId) && resourceTenantMatches(tenantId);
      }

      match /returns/{returnId} {
        allow read: if tenantMember(tenantId);
        allow create: if canSell(tenantId) && validReturn(tenantId);
        allow update, delete: if false;
      }

      match /stockMovements/{movementId} {
        allow read: if tenantMember(tenantId);
        allow create: if (canManageStock(tenantId) || canSell(tenantId)) && validMovement(tenantId);
        allow update, delete: if false;
      }

      match /purchases/{purchaseId} {
        allow read: if tenantMember(tenantId);
        allow create, update: if canManageStock(tenantId) && payloadTenantMatches(tenantId);
        allow delete: if canManageEverything(tenantId) && resourceTenantMatches(tenantId);
      }

      match /suppliers/{supplierId} {
        allow read: if tenantMember(tenantId);
        allow create, update: if canManageStock(tenantId) && payloadTenantMatches(tenantId);
        allow delete: if canManageEverything(tenantId) && resourceTenantMatches(tenantId);
      }

      match /stockCounts/{countId} {
        allow read: if tenantMember(tenantId);
        allow create, update: if canManageStock(tenantId) && payloadTenantMatches(tenantId);
        allow delete: if canManageEverything(tenantId) && resourceTenantMatches(tenantId);
      }

      match /shifts/{shiftId} {
        allow read: if tenantMember(tenantId);
        allow create, update: if canSell(tenantId) && payloadTenantMatches(tenantId);
        allow delete: if canManageStore(tenantId) && resourceTenantMatches(tenantId);
      }

      match /customers/{customerId} {
        allow read: if tenantMember(tenantId);
        allow create, update: if canSell(tenantId) && payloadTenantMatches(tenantId);
        allow delete: if canManageStore(tenantId) && resourceTenantMatches(tenantId);
      }

      match /memberships/{userId} {
        allow read: if tenantMember(tenantId) || request.auth.uid == userId;
        allow create, update, delete: if canManageMembers(tenantId);
      }

      match /notificationTokens/{tokenId} {
        allow read: if tenantMember(tenantId);
        allow create, update: if tenantMember(tenantId) && request.resource.data.uid == request.auth.uid;
        allow delete: if signedIn() && (resource.data.uid == request.auth.uid || canManageStore(tenantId));
      }

      match /deliveryCustomers/{customerId} {
        allow read, write: if canManageStore(tenantId);
      }

      match /tables/{tableId} {
        allow read: if true;
        allow write: if canSell(tenantId) || canManageStore(tenantId);
      }

      match /orders/{orderId} {
        allow get: if true;
        allow list: if tenantMember(tenantId);
        allow create: if payloadTenantMatches(tenantId) || tenantMember(tenantId);
        allow update: if canSell(tenantId) || canManageStore(tenantId);
        allow delete: if canManageEverything(tenantId);
      }
    }

    match /shops/{shopId}/{document=**} {
      allow read: if superAdminRole();
      allow write: if false;
    }
  }
}
