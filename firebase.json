{
  "hosting": {
    "target": "foodapp",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/delivery/success/**",
        "destination": "/delivery/success/index.html"
      },
      { "source": "/delivery/**", "destination": "/delivery/index.html" },
      { "source": "/verify/**", "destination": "/verify/index.html" },
      { "source": "/order/**", "destination": "/order/index.html" },
      { "source": "/kitchen/**", "destination": "/kitchen/index.html" },
      {
        "source": "/cashier/receipt/**",
        "destination": "/cashier/receipt/index.html"
      },
      {
        "source": "/cashier/table-qr/**",
        "destination": "/cashier/table-qr/index.html"
      },
      { "source": "/cashier/**", "destination": "/cashier/index.html" },
      {
        "source": "/admin/qr/**",
        "destination": "/admin/qr/index.html"
      },
      { "source": "/admin/**", "destination": "/admin/index.html" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": { "rules": "storage.rules" }
}
