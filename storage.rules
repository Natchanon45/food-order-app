rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function staffProfile() {
      return firestore.get(
        /databases/(default)/documents/users/$(request.auth.uid)
      ).data;
    }

    function hasRole(roles) {
      return signedIn()
        && staffProfile().active == true
        && staffProfile().role in roles;
    }

    function adminRole() {
      return hasRole(['owner', 'admin', 'super_admin']);
    }

    function staffRole() {
      return hasRole(['owner', 'admin', 'super_admin', 'cashier', 'kitchen']);
    }

    function validImage(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('image/.*');
    }

    function tenantOwner(tenantId) {
      return signedIn()
        && (
          firestore.get(/databases/(default)/documents/tenants/$(tenantId)).data.ownerUid == request.auth.uid
          || firestore.get(/databases/(default)/documents/tenants/$(tenantId)).data.ownerEmail == request.auth.token.email
        );
    }

    function userTenantProductAdmin(tenantId) {
      return signedIn()
        && staffProfile().active == true
        && staffProfile().tenantId == tenantId
        && staffProfile().role in ['owner', 'admin', 'super_admin'];
    }

    function membershipTenantProductAdmin(tenantId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/tenants/$(tenantId)/memberships/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/tenants/$(tenantId)/memberships/$(request.auth.uid)).data.active == true
        && firestore.get(/databases/(default)/documents/tenants/$(tenantId)/memberships/$(request.auth.uid)).data.role in ['owner', 'admin', 'super_admin'];
    }

    function tenantProductAdmin(tenantId) {
      return tenantOwner(tenantId)
        || userTenantProductAdmin(tenantId)
        || membershipTenantProductAdmin(tenantId);
    }

    match /menu-images/{menuId}/{fileName} {
      allow read: if true;
      allow create, update: if adminRole() && validImage(8 * 1024 * 1024);
      allow delete: if adminRole();
    }

    match /tenants/{tenantId}/product-images/{productId}/{fileName} {
      allow read: if true;
      allow create, update: if tenantProductAdmin(tenantId) && validImage(5 * 1024 * 1024);
      allow delete: if tenantProductAdmin(tenantId);
    }

    match /payment-slips/{orderId}/{fileName} {
      allow create: if validImage(8 * 1024 * 1024);
      allow read: if staffRole();
      allow update: if false;
      allow delete: if hasRole(['owner', 'super_admin']);
    }

    match /tenants/{tenantId}/payment-slips/{orderId}/{fileName} {
      allow create: if validImage(8 * 1024 * 1024);
      allow read: if staffRole();
      allow update: if false;
      allow delete: if hasRole(['owner', 'super_admin']);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
